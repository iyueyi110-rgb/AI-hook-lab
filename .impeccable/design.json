  "narrative": {
    "northStar": "The Editorial Workbench",
    "overview": "AI Hook Lab 把编辑部的清晰判断力带进创作工具。冷白纸面和石墨文字承载高密度内容，品牌红只用于最重要的动作、选择与强调。界面的张力来自排版比例、列结构和信息先后，而不是背景花纹或视觉特效。",
    "keyCharacteristics": ["冷静纸面上的高对比编辑结构", "创作台聚焦，看板可扫描", "少量、明确、可解释的品牌红", "状态完整且支持键盘操作"],
    "rules": [
      { "name": "The Red Pen Rule", "body": "品牌红在单屏只承担一个视觉焦点；成功、警告和错误使用真实语义色。", "section": "colors" },
      { "name": "The One Family Rule", "body": "产品界面只使用一套无衬线字体，通过层级表达性格。", "section": "typography" },
      { "name": "The Flat-by-Default Rule", "body": "静止表面依靠色阶和边界分层，阴影只说明真实层级变化。", "section": "elevation" }
    ],
    "dos": ["Do 让生成、比较、复制、收藏和采用保持在同一视线流中。", "Do 明确区分模型评分、人工满意度和数据来源。", "Do 为所有状态提供可恢复反馈。"],
    "donts": ["Don't 做成蓝紫渐变的通用 AI SaaS 或霓虹娱乐工具。", "Don't 堆满相同卡片或重新加入方格纸式装饰背景。", "Don't 用宽阴影、玻璃模糊和发光效果替代真实层级。"]
