# Required to generate hooks. Keep the real key only in .env.local.
DEEPSEEK_API_KEY=

# Required in production. Optional only for local development, where an empty value uses local JSON fallback.
DATABASE_URL=

# Optional: override the local evaluation JSON path (useful for isolated smoke tests).
EVALUATION_STORE_PATH=

# Optional: override the Creative Coach local JSON store path in development.
AGENT_STORE_PATH=

# Optional: required only when the evaluation script writes evaluation events.
EVAL_INGEST_TOKEN=

# Optional: enables screenshot analysis through a vision model in Volcengine Ark.
# Keep the real key only in .env.local. Use the model or endpoint ID enabled in Ark.
ARK_API_KEY=
ARK_MODEL_ID=

# Optional: enables the browser creative coach mode. Keep disabled until the Agent APIs are verified.
NEXT_PUBLIC_AGENT_COACH_ENABLED=false
AGENT_CLEANUP_TOKEN=replace_me

# Required in production to HMAC client IPs for anonymous abuse quotas. Never reuse an API key.
AGENT_IP_HASH_SECRET=replace_me
# Header overwritten by the trusted deployment proxy (Vercel default shown).
AGENT_TRUSTED_IP_HEADER=x-vercel-forwarded-for
# Optional quota overrides (safe defaults apply when omitted).
AGENT_QUOTA_WINDOW_SECONDS=3600
AGENT_QUOTA_SESSION_RUNS=10
AGENT_QUOTA_IP_RUNS=30
AGENT_QUOTA_SESSION_MODEL_CALLS=30
AGENT_QUOTA_IP_MODEL_CALLS=100
AGENT_QUOTA_SESSION_IMAGE_CALLS=10
AGENT_QUOTA_IP_IMAGE_CALLS=30
AGENT_QUOTA_MAX_ACTIVE_RUNS=3
